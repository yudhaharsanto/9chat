# ============================================
# 9Chat Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# ── Database ── Choose ONE:

# Option A: Supabase (recommended for quick start)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Option B: Standalone PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/9chat

# ── Notes ──
# - 9router URL & API key are configured in Admin → Connection (stored in DB)
# - ImgBB API key is configured in Admin → Connection (stored in DB)
# - Admin default password: admin (change in Admin → Security)
